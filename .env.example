# =============================================================================
# AI DevSecOps Showcase — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI (required by both scenarios)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Optional: embedding model deployment (used for semantic clustering in Scenario 1)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# -----------------------------------------------------------------------------
# Azure DevOps (required by both scenarios)
# -----------------------------------------------------------------------------
ADO_ORGANIZATION_URL=https://dev.azure.com/<your-org>
ADO_PROJECT=<your-project-name>
ADO_PAT=<your-personal-access-token>

# Scenario 1: pipeline definitions to monitor (comma-separated pipeline IDs or names)
ADO_PIPELINE_IDS=1,2,3

# Scenario 1: Wiki configuration
ADO_WIKI_ID=<your-wiki-id>
ADO_WIKI_PATH=/Build-Intelligence/Failure-Report

# Scenario 2: PR integration — repository ID for posting review comments
ADO_REPOSITORY_ID=<your-repo-id>

# -----------------------------------------------------------------------------
# Confluence (Scenario 2 only)
# -----------------------------------------------------------------------------
CONFLUENCE_URL=https://<your-org>.atlassian.net
CONFLUENCE_USERNAME=<your-confluence-email>
CONFLUENCE_API_TOKEN=<your-confluence-api-token>

# Space key(s) to pull standards from (comma-separated)
CONFLUENCE_SPACE_KEYS=ENG,DEVOPS

# Optional: specific page IDs to always include
CONFLUENCE_STANDARDS_PAGE_IDS=

# -----------------------------------------------------------------------------
# Agent tuning (optional — defaults shown)
# -----------------------------------------------------------------------------
# Maximum number of build runs to fetch per analysis cycle
MAX_BUILD_RUNS=100

# Minimum failures required to form a cluster
MIN_CLUSTER_SIZE=2

# GPT temperature for analysis tasks (0.0 = deterministic)
GPT_TEMPERATURE=0.2

# Maximum tokens per GPT response
GPT_MAX_TOKENS=2000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
